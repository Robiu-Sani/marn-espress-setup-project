<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <style>
      body { font-family: 'Inter', sans-serif; background-color: #0a0a0c; color: #e0e0e0; margin: 0; }
      .container { max-width: 600px; margin: 40px auto; background-color: #121214; border-radius: 12px; border: 1px solid #2d2d30; overflow: hidden; }
      .header { background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%); padding: 40px; text-align: center; color: white; }
      .content { padding: 40px; }
      .invoice-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
      .invoice-table th { text-align: left; color: #888; font-size: 12px; text-transform: uppercase; padding-bottom: 10px; }
      .invoice-table td { padding: 15px 0; border-top: 1px solid #2d2d30; color: #fff; }
      .total-row td { font-size: 18px; font-weight: bold; color: #10b981; border-top: 2px solid #2d2d30; }
      .footer { background-color: #0a0a0c; padding: 25px; text-align: center; font-size: 12px; color: #666; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div style="font-size: 12px; text-transform: uppercase; margin-bottom: 8px;">Payment Successful</div>
        <h1 style="margin:0;">Thank You!</h1>
      </div>
      <div class="content">
        <p>Hi {{userName}}, your payment has been processed successfully. Here are your transaction details:</p>
        <table class="invoice-table">
          <thead>
            <tr><th>Description</th><th style="text-align: right;">Amount</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>{{planName}} Subscription</td>
              <td style="text-align: right;">{{amount}}</td>
            </tr>
            <tr class="total-row">
              <td>Total Paid</td>
              <td style="text-align: right;">{{amount}}</td>
            </tr>
          </tbody>
        </table>
        <p style="font-size: 13px; color: #888;">Transaction ID: {{transactionId}}</p>
      </div>
      <div class="footer">
        <p>Engineered by Robius Sani | Code Biruni</p>
      </div>
    </div>
  </body>
</html>