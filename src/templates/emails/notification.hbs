<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>mern-setup-system Notification</title>
    <style>
      body {
        font-family: 'Inter', 'Segoe UI', Helvetica, Arial, sans-serif;
        line-height: 1.6;
        color: #e0e0e0;
        margin: 0;
        padding: 0;
        background-color: #0a0a0c;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background-color: #121214;
        border: 1px solid #2d2d30;
        border-radius: 8px;
        overflow: hidden;
      }
      .header {
        background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%);
        padding: 40px 20px;
        text-align: center;
        color: white;
      }
      .package-badge {
        background: rgba(255, 255, 255, 0.2);
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        margin-bottom: 10px;
      }
      .logo-text {
        font-size: 24px;
        font-weight: 800;
        margin: 0;
      }
      .content {
        padding: 30px;
        background-color: #121214;
      }
      .notification-box {
        background-color: #1c1c1f;
        border-left: 4px solid #4f46e5;
        padding: 20px;
        margin: 25px 0;
        border-radius: 4px;
      }
      .notification-title {
        color: #ffffff;
        margin-top: 0;
        font-size: 18px;
      }
      .notification-date {
        color: #888;
        font-size: 12px;
        margin-bottom: 8px;
      }
      .action-button {
        display: inline-block;
        padding: 12px 30px;
        background: #4f46e5;
        color: #ffffff !important;
        text-decoration: none;
        border-radius: 6px;
        margin: 15px 0;
        font-weight: bold;
        transition: background 0.3s ease;
      }
      .footer {
        background-color: #0a0a0c;
        padding: 25px;
        text-align: center;
        font-size: 12px;
        color: #666;
        border-top: 1px solid #2d2d30;
      }
      .footer a {
        color: #06b6d4;
        text-decoration: none;
      }
      .priority-high { border-left-color: #ef4444; background-color: #241414; }
      .priority-medium { border-left-color: #f59e0b; background-color: #241f14; }
      .priority-low { border-left-color: #10b981; background-color: #14241b; }
      
      .brand-footer {
        margin-top: 10px;
        color: #4f46e5;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div class="package-badge">mern-setup-system</div>
        <h1 class="logo-text">CODE BIRUNI</h1>
        <div style="opacity: 0.9;">System Alert & Notification</div>
      </div>

      <div class="content">
        <h2 style="color: #ffffff;">Hello {{userName}},</h2>
        <p>You have received a new update from the <strong>mern-setup-system</strong> environment:</p>

        <div class="notification-box {{priorityClass}}">
          <div class="notification-date">{{notificationDate}}</div>
          <h3 class="notification-title">{{title}}</h3>
          <div style="color: #b0b0b0;">{{{message}}}</div>
        </div>

        {{#if actionUrl}}
          <p style="text-align: center;">
            <a href="{{actionUrl}}" class="action-button">View Details</a>
          </p>
        {{/if}}

        <p style="font-size: 14px; color: #888;">
          This message was generated by the <strong>mern-setup-system</strong> CLI tool. 
          If you didn't expect this notification, please verify your configuration settings.
        </p>
      </div>

      <div class="footer">
        <p>© <span id="currentYear"></span> <strong>Code Biruni</strong>. All Rights Reserved.</p>
        <p>Developed & Maintained by <strong>Robius Sani</strong></p>
        <p>Support: <a href="mailto:hafazrobiussani@gmail.com">hafazrobiussani@gmail.com</a></p>
        <div class="brand-footer">Building the Future of Full-Stack Development</div>
      </div>
    </div>

    <script>
      document.getElementById('currentYear').textContent = new Date().getFullYear();
    </script>
  </body>
</html>